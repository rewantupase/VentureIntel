# ── Local LLM (Required — runs via Ollama, no API key needed) ───────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3

# ── PostgreSQL (sessions / reports / risk scores) ────────────────────
DATABASE_URL=postgresql+asyncpg://intel:intel_pass@postgres:5432/intel_db

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── ChromaDB (vector store) ──────────────────────────────────────────
# Docker mode: set CHROMA_HOST to the service name
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# Local dev mode: leave CHROMA_HOST blank — uses embedded ChromaDB on disk

# ── Optional API Keys (leave blank to use demo/mock data) ────────────
BRAVE_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
GITHUB_TOKEN=
NEWSAPI_KEY=
LINKEDIN_TOKEN=

# ── Monitoring (optional) ─────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Report output ─────────────────────────────────────────────────────
REPORTS_DIR=/tmp/reports
